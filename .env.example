# === Pagaza Abogados — Variables de Entorno ===
# Copia este archivo a .env.local y rellena/ajusta los valores.
# TODOS los servicios de PRODUCCIÓN se crean en cuentas/teams de BROTA (separado de Galarza/Personal).
# Nunca commitees .env.local. Los valores de "test" de abajo son públicos (de Cloudflare/Resend),
# NO son secretos: existen para que el formulario y /verify sean ejecutables en DEV (hallazgo A3).

# --- Correo del formulario (Resend) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=a@pagaza.mx
# DEV: usa el sandbox de Resend, que envía sin dominio verificado (solo al dueño de la cuenta).
# PROD: cambiar a no-reply@pagaza.mx SOLO cuando pagaza.mx esté verificado en Resend (SPF/DKIM/DMARC).
CONTACT_FROM_EMAIL=onboarding@resend.dev

# --- Newsletter (Resend Audiences) ---
# ID de la audiencia donde se dan de alta las suscripciones. Si queda VACÍA, /api/newsletter se
# degrada a enviar un aviso por correo a CONTACT_TO_EMAIL: preferimos que el alta llegue por un
# canal menos cómodo a perderla porque falta una variable. Ver lib/resend.ts.
RESEND_AUDIENCE_ID=

# --- Rate limiting (Upstash Redis) ---
# Si ambas quedan vacías en DEV, el limitador hace fail-open (permite) — ver lib/ratelimit.ts (trampa 6.2).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Anti-bot (Cloudflare Turnstile) ---
# Llaves de PRUEBA oficiales de Cloudflare (públicas): el widget siempre pasa y siteverify siempre
# aprueba. Úsalas en DEV para poder enviar el formulario localmente. En PROD, reemplázalas por las
# llaves reales del dashboard de Turnstile (cuenta Brota).
#   Site key de prueba (siempre pasa):    1x00000000000000000000AA
#   Site key de prueba (siempre bloquea): 2x00000000000000000000AB
#   Secret de prueba (siempre aprueba):   1x0000000000000000000000000000000AA
#   Secret de prueba (siempre falla):     2x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Bypass opcional en DEV: si NEXT_PUBLIC_TURNSTILE_SITE_KEY queda VACÍA, el ContactForm no monta el
# widget y el handler omite la verificación (solo cuando NODE_ENV !== "production"). Ver Fase 7.

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Reporter a la Torre de Control (fail-open) ---
TORRE_REPORTER_URL=
