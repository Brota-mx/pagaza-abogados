# === Pagaza Abogados — Variables de Entorno ===
# Copia este archivo a .env.local y rellena los valores reales.
# TODOS los servicios deben crearse en cuentas/teams de BROTA (separado de Galarza/Personal).
# Nunca commitees .env.local.

# --- Correo del formulario (Resend) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=a@pagaza.mx
CONTACT_FROM_EMAIL=no-reply@pagaza.mx

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Anti-bot (Cloudflare Turnstile) ---
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Reporter a la Torre de Control (fail-open) ---
TORRE_REPORTER_URL=
